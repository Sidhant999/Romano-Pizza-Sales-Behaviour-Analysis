<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Pizza Sales Analysis 2.db" readonly="0" foreign_keys="0" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1646"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="pizza_sales" custom_title="0" dock_id="3" table="4,11:mainpizza_sales"/><table title="pizza_sales" custom_title="0" dock_id="4" table="4,11:mainpizza_sales"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="pizza_sales_cleaned" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="63"/><column index="2" value="63"/><column index="3" value="62"/><column index="4" value="79"/><column index="5" value="79"/><column index="6" value="75"/><column index="7" value="79"/><column index="8" value="76"/><column index="9" value="108"/><column index="10" value="230"/><column index="11" value="50"/><column index="12" value="93"/><column index="13" value="92"/><column index="14" value="57"/><column index="15" value="38"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">--Q1 → What is the total revenue?    Done
SELECT round(sum(total_price),2) as total_revenue
from pizza_sales;

--Q2 → What is the total number of orders?   
SELECT count(distinct ORDER_ID) AS TOTAL_NUMBER_OF_ORDER
FROM pizza_sales;

--Q3 → What is the total pizzas sold?
select sum(quantity) as total_pizza_sold
from pizza_sales;

--Q4 → What is the average order value?
select round(sum(total_price)/count(distinct order_id), 2) as avg_order_value
from pizza_sales;

--Q5 → What is the total revenue by month?
select month, month_name, round(sum(total_price),2 ) as total_revenue_monthly
from pizza_sales
group by month, month_name
order by month;

--Q6 → What is the total orders by day of week?
select day_of_week, count(distinct ORDER_ID) total_order_by_day_of_week
from pizza_sales
group by day_of_week
order by total_order_by_day_of_week desc;

--Q7 → What is the total orders by hour?
select hour, count(distinct order_id) as total_order_by_hour
from pizza_sales
group by hour
order by total_order_by_hour desc;

--Q8  → Which are the top 5 pizzas by revenue?
select pizza_name, round(sum(total_price),2) as revenue
from pizza_sales
group by pizza_name
order by revenue desc
limit 5;

--Q9  → Which are the bottom 5 pizzas by revenue?
select pizza_name, round(sum(total_price),2) as revenue
from pizza_sales
group by pizza_name
order by revenue asc
limit 5;

--Q10 → What is the revenue by pizza category?
select pizza_category, round(sum(total_price),2) as total_revenue_pizza_category
from pizza_sales
group by pizza_category
order by total_revenue_pizza_category desc;

--Q11 → What is the revenue by pizza size?
select pizza_size, round(sum(total_price),2) as total_revenue_pizza_size
from pizza_sales
group by pizza_size
order by total_revenue_pizza_size desc;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
